{
  "manifest_version": 3,
  "name": "Social Post Monitor Pro",
  "version": "2.0.0",
  "description": "Professional analytics sidebar for Facebook & Instagram \u2014 stats, charts, comments, profile, bulk download",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "notifications"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://www.instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://www.instagram.com/*"
      ],
      "js": [
        "content/injector.js"
      ],
      "css": [
        "content/sidebar.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Social Post Monitor Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/*",
        "icons/*",
        "dashboard/*"
      ],
      "matches": [
        "https://www.facebook.com/*",
        "https://www.instagram.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}